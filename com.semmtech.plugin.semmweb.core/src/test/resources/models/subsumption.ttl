@base          <http://www.example.org/subsumption/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix prb:   <http://www.example.org/problems/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

prb:hassomethingother
        a           rdf:Property ;
        rdfs:label  "hasSomethingOther" .

prb:Sub  a               owl:Class ;
        rdfs:label       "Sub" ;
        rdfs:subClassOf  prb:Super ;
        rdfs:subClassOf  [ a                         owl:Restriction ;
                           owl:onClass               rdfs:Literal ;
                           owl:onProperty            prb:hassomething ;
                           owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger
                         ] ;
        rdfs:subClassOf  [ a                  owl:Restriction ;
                           owl:allValuesFrom  prb:Sub ;
                           owl:onProperty     prb:hassomething
                         ] .

prb:    a           owl:Ontology ;
        rdfs:label  "Restrictions Subsumption" .

prb:Super  a             owl:Class ;
        rdfs:label       "Super" ;
        rdfs:subClassOf  owl:Thing ;
        rdfs:subClassOf  [ a                   owl:Restriction ;
                           owl:onProperty      prb:hassomething ;
                           owl:someValuesFrom  rdfs:Literal
                         ] ;
        rdfs:subClassOf  [ a                  owl:Restriction ;
                           owl:allValuesFrom  prb:Super ;
                           owl:onProperty     prb:hassomething
                         ] .

prb:SubSub  a            owl:Class ;
        rdfs:label       "SubSub" ;
        rdfs:subClassOf  prb:Sub ;
        rdfs:subClassOf  [ a                owl:Restriction ;
                           owl:cardinality  "0"^^xsd:nonNegativeInteger ;
                           owl:onProperty   prb:hassomething
                         ] ;
        rdfs:subClassOf  [ a                  owl:Restriction ;
                           owl:allValuesFrom  prb:SubSub ;
                           owl:onProperty     prb:hassomething
                         ] .

prb:hassomething  a  rdf:Property ;
        rdfs:domain  prb:Super ;
        rdfs:label   "hasSomething" .
