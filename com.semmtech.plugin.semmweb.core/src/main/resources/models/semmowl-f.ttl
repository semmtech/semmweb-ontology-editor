        a                   spin:Function ;
        rdfs:comment        "Checks whether a given resource conforms to the upper bound requirements placed on it by the given owl:maxQualifiedCardinality or owl:qualifiedCardinality restriction (not also for any restrictions that are super classes of the given restriction)." ;
