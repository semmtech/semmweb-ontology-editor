        spin:labelTemplate  "Max qualified cardinality satisfaction check for a resource (using {?arg1}, {?arg2}, {?arg3})"^^xsd:string .




_:b_minCardinality    sp:varName  "minCardinality"^^xsd:string .
_:b_maxCardinality    sp:varName  "maxCardinality"^^xsd:string .
_:b_onProperty        sp:varName  "onProperty"^^xsd:string .
_:b_onClass           sp:varName  "onClass"^^xsd:string .
_:b_objectCount       sp:varName  "objectCount"^^xsd:string .
_:b_property          sp:varName  "property"^^xsd:string .
_:b_object            sp:varName  "object"^^xsd:string .
