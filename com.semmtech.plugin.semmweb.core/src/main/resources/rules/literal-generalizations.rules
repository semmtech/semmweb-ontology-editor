@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .


[literals: (?s ?p ?o), isLiteral(?o), makeTemp(?x), notEqual(?p, rdf:value) 
    -> (?x rdf:type rdfs:Literal), (?x rdf:value ?o), (?s ?p ?x) ]
[non-literals: (?s ?p ?o), notLiteral(?o) 
    -> (?s ?p ?o) ]

