          <owl:FunctionalProperty rdf:about="#hasBody"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Anjou">
    <owl:intersectionOf rdf:parseType="Collection">
      <owl:Class rdf:about="#Loire"/>
      <owl:Restriction>
        <owl:hasValue>
          <vin:Region rdf:ID="AnjouRegion">
            <vin:locatedIn rdf:resource="#LoireRegion"/>
          </vin:Region>
        </owl:hasValue>
        <owl:onProperty>
          <owl:TransitiveProperty rdf:about="#locatedIn"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:intersectionOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:hasValue rdf:resource="#OffDry"/>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:about="#hasSugar"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:hasValue rdf:resource="#Delicate"/>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:about="#hasFlavor"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:hasValue rdf:resource="#Light"/>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:about="#hasBody"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:hasValue rdf:resource="#Rose"/>
        <owl:onProperty>
