        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Gamay">
    <owl:intersectionOf rdf:parseType="Collection">
      <owl:Class rdf:about="#Wine"/>
      <owl:Restriction>
        <owl:hasValue rdf:resource="#GamayGrape"/>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#madeFromGrape"/>
        </owl:onProperty>
      </owl:Restriction>
      <owl:Restriction>
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
        >1</owl:maxCardinality>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#madeFromGrape"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:intersectionOf>
  </owl:Class>
  <owl:Class rdf:about="#ItalianWine">
    <owl:intersectionOf rdf:parseType="Collection">
      <owl:Class rdf:about="#Wine"/>
      <owl:Restriction>
        <owl:hasValue rdf:resource="#ItalianRegion"/>
        <owl:onProperty>
          <owl:TransitiveProperty rdf:about="#locatedIn"/>
        </owl:onProperty>
      </owl:Restriction>
    </owl:intersectionOf>
  </owl:Class>
  <owl:Class rdf:ID="Vintage">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
        >1</owl:cardinality>
        <owl:onProperty>
          <owl:FunctionalProperty rdf:ID="hasVintageYear"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:ObjectProperty rdf:about="#madeFromGrape">
    <rdfs:range rdf:resource="#WineGrape"/>
    <rdfs:domain rdf:resource="#Wine"/>
    <rdfs:subPropertyOf rdf:resource="http://www.w3.org/TR/2003/PR-owl-guide-20031209/food#madeFromFruit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="producesWine">
    <owl:inverseOf>
      <owl:FunctionalProperty rdf:about="#hasMaker"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="hasWineDescriptor">
    <rdfs:range rdf:resource="#WineDescriptor"/>
    <rdfs:domain rdf:resource="#Wine"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="madeIntoWine">
    <owl:inverseOf rdf:resource="#madeFromGrape"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:ID="yearValue">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
    <rdfs:domain rdf:resource="#VintageYear"/>
  </owl:DatatypeProperty>
  <owl:TransitiveProperty rdf:about="#locatedIn">
    <rdfs:range rdf:resource="#Region"/>
    <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:TransitiveProperty>
  <owl:SymmetricProperty rdf:ID="adjacentRegion">
    <rdfs:range rdf:resource="#Region"/>
    <rdfs:domain rdf:resource="#Region"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:SymmetricProperty>
  <owl:FunctionalProperty rdf:about="#hasVintageYear">
    <rdfs:range rdf:resource="#VintageYear"/>
    <rdfs:domain rdf:resource="#Vintage"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="#hasFlavor">
    <rdfs:range rdf:resource="#WineFlavor"/>
    <rdfs:subPropertyOf rdf:resource="#hasWineDescriptor"/>
