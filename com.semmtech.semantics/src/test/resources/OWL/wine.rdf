  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="#hasSugar">
    <rdfs:range rdf:resource="#WineSugar"/>
    <rdfs:subPropertyOf rdf:resource="#hasWineDescriptor"/>
