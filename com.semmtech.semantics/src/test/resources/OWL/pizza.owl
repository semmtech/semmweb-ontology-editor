        <owl:onProperty>
          <owl:FunctionalProperty rdf:about="#hasSpiciness"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="#CheeseTopping"/>
    <rdfs:label xml:lang="pt">CoberturaDeParmesao</rdfs:label>
  </owl:Class>
