    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <owl:Restriction>
            <owl:someValuesFrom rdf:resource="#Hot"/>
            <owl:onProperty>
              <owl:FunctionalProperty rdf:about="#hasSpiciness"/>
            </owl:onProperty>
          </owl:Restriction>
          <owl:Class rdf:about="#PizzaTopping"/>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
