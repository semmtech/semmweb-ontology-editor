@prefix afn:   <http://jena.hpl.hp.com/ARQ/function#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sp:    <http://spinrdf.org/sp#> .
@prefix spinrdfs: <http://topbraid.org/spin/spinrdfs#> .
@prefix spl:   <http://spinrdf.org/spl#> .
@prefix smf:   <http://topbraid.org/sparqlmotionfunctions#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix spin:  <http://spinrdf.org/spin#> .


<http://topbraid.org/spin/spinrdfs>
        a                owl:Ontology ;
        rdfs:comment     "Contains axioms to run constraint checks on a subset of RDF Schema." ;
        owl:imports      <http://spinrdf.org/spin> ;
        owl:versionInfo  "0.1.1"^^xsd:string .


rdfs:Resource  spin:constraint  [ a  spinrdfs:RangeConstraint ] .


spinrdfs:RangeConstraint
        a                   spin:Template ;
        rdfs:comment        "Checks whether all property values of ?this have a type compatible with the declared rdfs:ranges on the property, or have no type."^^xsd:string ;
        rdfs:label          "Range constraint"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a             sp:Construct ;
                              sp:templates  ( [ sp:object     spin:ConstraintViolation ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    _:b0
                                              ] [ sp:object     _:b1 ;
                                                  sp:predicate  rdfs:label ;
                                                  sp:subject    _:b0
                                                ] [ sp:object     spin:_this ;
                                                    sp:predicate  spin:violationRoot ;
                                                    sp:subject    _:b0
                                                  ] [ sp:object     _:b2 ;
                                                      sp:predicate  spin:violationPath ;
                                                      sp:subject    _:b0
                                                    ] ) ;
                              sp:where      ( [ a              sp:Filter ;
                                                sp:expression  [ a        sp:and ;
                                                                 sp:arg1  [ a        sp:isURI ;
                                                                            sp:arg1  spin:_this
                                                                          ] ;
                                                                 sp:arg2  [ a        sp:not ;
                                                                            sp:arg1  [ a        spinrdfs:isSystem ;
                                                                                       sp:arg1  spin:_this
                                                                                     ]
                                                                          ]
                                                               ]
                                              ] [ sp:object     _:b3 ;
                                                  sp:predicate  _:b2 ;
                                                  sp:subject    spin:_this
                                                ] [ a              sp:Filter ;
                                                    sp:expression  [ a        sp:isURI ;
                                                                     sp:arg1  _:b3
                                                                   ]
                                                  ] [ a           sp:TriplePath ;
                                                      sp:object   _:b4 ;
                                                      sp:path     [ a           sp:ModPath ;
                                                                    sp:modMax   -2 ;
                                                                    sp:modMin   0 ;
                                                                    sp:subPath  rdfs:subPropertyOf
                                                                  ] ;
                                                      sp:subject  _:b2
                                                    ] [ sp:object     _:b5 ;
                                                        sp:predicate  rdfs:range ;
                                                        sp:subject    _:b4
                                                      ] [ a              sp:Filter ;
                                                          sp:expression  [ a        sp:ne ;
                                                                           sp:arg1  _:b5 ;
                                                                           sp:arg2  rdfs:Literal
                                                                         ]
                                                        ] [ a              sp:Filter ;
                                                            sp:expression  [ a        sp:and ;
                                                                             sp:arg1  [ a        spl:hasValue ;
                                                                                        sp:arg1  _:b3 ;
                                                                                        sp:arg2  rdf:type ;
                                                                                        sp:arg3  [ sp:varName  "anyType"^^xsd:string ]
                                                                                      ] ;
                                                                             sp:arg2  [ a        sp:not ;
                                                                                        sp:arg1  [ a        spl:instanceOf ;
                                                                                                   sp:arg1  _:b3 ;
                                                                                                   sp:arg2  _:b5
                                                                                                 ]
                                                                                      ]
                                                                           ]
                                                          ] [ a              sp:Let ;
                                                              sp:expression  [ a        smf:buildString ;
                                                                               sp:arg1  "Range violation: {?range} expected for {?value} at {?property}"
                                                                             ] ;
                                                              sp:variable    _:b1
                                                            ] )
                            ] ;
        spin:labelTemplate  "rdfs:range constraint"^^xsd:string .


spinrdfs:isSystem  a     spin:Function ;
        rdfs:comment     "Checks whether a given resource (?arg1) is from the RDF, RDFS or OWL namespace." ;
        rdfs:label       "is system"^^xsd:string ;
        rdfs:subClassOf  spin:Functions ;
        spin:body        [ a         sp:Ask ;
                           sp:where  ( [ a              sp:Let ;
                                         sp:expression  [ a        afn:namespace ;
                                                          sp:arg1  spin:_arg1
                                                        ] ;
                                         sp:variable    sp:_ns
                                       ] [ a              sp:Filter ;
                                           sp:expression  [ a        sp:or ;
                                                            sp:arg1  [ a        sp:or ;
                                                                       sp:arg1  [ a        sp:eq ;
                                                                                  sp:arg1  sp:_ns ;
                                                                                  sp:arg2  [ a        xsd:string ;
                                                                                             sp:arg1  owl:
                                                                                           ]
                                                                                ] ;
                                                                       sp:arg2  [ a        sp:eq ;
                                                                                  sp:arg1  sp:_ns ;
                                                                                  sp:arg2  [ a        xsd:string ;
                                                                                             sp:arg1  rdfs:
                                                                                           ]
                                                                                ]
                                                                     ] ;
                                                            sp:arg2  [ a        sp:eq ;
                                                                       sp:arg1  sp:_ns ;
                                                                       sp:arg2  [ a        xsd:string ;
                                                                                  sp:arg1  rdf:
                                                                                ]
                                                                     ]
                                                          ]
                                         ] )
                         ] ;
        spin:constraint  [ a              spl:Argument ;
                           rdfs:comment   "the resource to check"^^xsd:string ;
                           spl:predicate  sp:arg1 ;
                           spl:valueType  rdfs:Resource
                         ] ;
        spin:returnType  xsd:boolean .





_:b1    sp:varName  "label"^^xsd:string .
_:b2    sp:varName  "property"^^xsd:string .
_:b3    sp:varName  "value"^^xsd:string .
_:b4    sp:varName  "p"^^xsd:string .
_:b5    sp:varName  "range"^^xsd:string .


sp:_ns  a           sp:Variable ;
        sp:varName  "ns"^^xsd:string .

sp:_label  a        sp:Variable ;
        sp:varName  "label"^^xsd:string .

sp:_p   a           sp:Variable ;
        sp:varName  "p"^^xsd:string .

sp:_property  a     sp:Variable ;
        sp:varName  "property"^^xsd:string .

sp:_rdf  a          sp:Variable ;
        sp:varName  "rdf"^^xsd:string .

sp:_value  a        sp:Variable ;
        sp:varName  "value"^^xsd:string .

sp:_range  a        sp:Variable ;
        sp:varName  "range"^^xsd:string .
