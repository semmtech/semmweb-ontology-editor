@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix spin:  <http://spinrdf.org/spin#> .
@prefix sp:    <http://spinrdf.org/sp#> .
@prefix spl:   <http://spinrdf.org/spl#> .
@prefix smf:   <http://topbraid.org/sparqlmotionfunctions#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix list:  <http://jena.hpl.hp.com/ARQ/list#> .

@prefix semmcore:  <http://www.semmweb.com/semmweb/core/functions#> .
@prefix semmowl: <http://www.semmtech.com/spin/semmowl#> .

semmowl:
        a                owl:Ontology ;
        rdfs:comment     "Contains constraint checking axioms for a subset of OWL 2, using closed-world semantics."^^xsd:string;
        owl:imports      <http://spinrdf.org/spl> .


rdfs:Class
        spin:rule [ a        semmowl:OneOfRule ] .

owl:Class
        spin:rule [ a        semmowl:SubclassOfThingRule ] .


owl:Class
        spin:constraint  [ a        semmowl:InconsistentMinMaxQualifiedCardinalityConstraint 
                         ] ;
        spin:constraint  [ a        semmowl:InconsistentAllValuesFromConstraint1
                         ] ;
        spin:constraint  [ a        semmowl:InconsistentAllValuesFromConstraint2
                         ] .

owl:Thing
        spin:constraint  [ a        semmowl:MinQualifiedCardinalityConstraint ;
                           sp:arg1  owl:qualifiedCardinality
                         ] ;
        spin:constraint  [ a        semmowl:MinQualifiedCardinalityConstraint ;
                           sp:arg1  owl:minQualifiedCardinality
                         ] ;
        spin:constraint  [ a        semmowl:MaxQualifiedCardinalityConstraint ;
                           sp:arg1  owl:qualifiedCardinality
                         ] ;
        spin:constraint  [ a        semmowl:MaxQualifiedCardinalityConstraint ;
                           sp:arg1  owl:maxQualifiedCardinality
                         ] .


semmowl:OneOfRule
        a                   spin:Template ;
        rdfs:comment        "Applies owl:oneOf inference, adding an rdf:type to all members in an RDF list that are object to an owl:oneOf predicate." ;
        rdfs:label          "OneOf rule"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a    sp:Construct ;
                              sp:templates  (
                                [ sp:subject    _:b_member ;
                                  sp:predicate  rdf:type ;
                                  sp:object     spin:_this
                                ]
                              ) ;
                              sp:where   (
                                [ sp:subject    spin:_this ;
                                  sp:predicate  owl:oneOf ;
                                  sp:object     _:b_list
                                ]
                                [ sp:subject    _:b_list ;
                                  sp:predicate  list:member ;
                                  sp:object     _:b_member
                                ] 
                              )
                            ] ;
        spin:labelTemplate  "OneOf rule"^^xsd:string .


semmowl:SubclassOfThingRule
        a                   spin:Template ;
        rdfs:comment        "Applies subClassOf owl:Thing inference, adding an rdfs:subClassOf owl:Thing property to an owl:Class." ;
        rdfs:label          "Sub Class of Thing rule"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a    sp:Construct ;
                              sp:templates  (
                                [ sp:subject    spin:_this ;
                                  sp:predicate  rdfs:subClassOf ;
                                  sp:object     owl:Thing
                                ]
                              ) ;
                            ] ;
        spin:labelTemplate  "Sub Class of Thing rule"^^xsd:string .




# Know that this is a check for classes rather than for instances!
# Does not check for inconsistent class on restrictions other than minQualifiedCardinality and maxQualifiedCardinality.
# Does not yet take subproperties for onProperty into account; only checks for equal onProperty. Should only produce an error when onProperty for the minimum cardinality is subPropertyOf* onProperty for the maximum cardinality 
semmowl:InconsistentMinMaxQualifiedCardinalityConstraint
        a                   spin:Template ;
        rdfs:comment        "Checks for any owl:minQualifiedCardinality restrictions defined in one of the superclasses of ?this and cross-checks them for consistency against other defined restrictions of the following types using closed-world semantics: maxQualifiedCardinality." ;
        rdfs:label          "Inconsistent cardinality constraint"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a             sp:Construct ;
                              sp:templates  ( [ sp:object     spin:ConstraintViolation ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    _:b1
                                              ] [ sp:object     _:b2 ;
                                                  sp:predicate  rdfs:label ;
                                                  sp:subject    _:b1
                                                ] [ sp:object     spin:_this ;
                                                    sp:predicate  spin:violationRoot ;
                                                    sp:subject    _:b1
                                                  ] [ sp:object     _:b3 ;
                                                      sp:predicate  spin:violationPath ;
                                                      sp:subject    _:b1
                                                    ] ) ;
                              sp:where      (  [ a           sp:TriplePath ;
                                                  sp:object   _:b0 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  spin:_this
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b0
                                                  ] [ sp:object     _:b7 ;
                                                      sp:predicate  owl:minQualifiedCardinality ;
                                                      sp:subject    _:b0
                                                    ] [ sp:object     _:b3 ;
                                                        sp:predicate  owl:onProperty ;
                                                        sp:subject    _:b0
                                                      ] [ sp:object     _:b8 ;
                                                        sp:predicate  owl:onClass ;
                                                        sp:subject    _:b0
                                                      ]
                                                      
                                                      
                                                 [ a           sp:TriplePath ;
                                                  sp:object   _:b10 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  spin:_this
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b10
                                                  ] [ sp:object     _:b15 ;
                                                      sp:predicate  owl:maxQualifiedCardinality ;
                                                      sp:subject    _:b10
                                                    ] [ sp:object     _:b3 ;
                                                        sp:predicate  owl:onProperty ;
                                                        sp:subject    _:b10
                                                      ] [ sp:object     _:b18 ;
                                                        sp:predicate  owl:onClass ;
                                                        sp:subject    _:b10
                                                      ] 
                                                      
                                                      
                                                      
                                                      [ a              sp:Filter ;
                                                            sp:expression  [ a        sp:lt ;
                                                                             sp:arg1  _:b15 ;
                                                                             sp:arg2  _:b7
                                                                           ]
                                                       ]
                                                      
                                                      [ a           sp:TriplePath ;
                                                          sp:object   _:b18 ;
                                                          sp:path     [ a           sp:ModPath ;
                                                                        sp:modMax   -2 ;
                                                                        sp:modMin   0 ;
                                                                        sp:subPath  rdfs:subClassOf
                                                                      ] ;
                                                          sp:subject  _:b8
                                                      ]
                                                      
                                                      
                                                      
                                                      
                                                        [ a              sp:Let ;
                                                              sp:expression  [ a        smf:buildString ;
                                                                               sp:arg1  "Class {?this} cannot be instantiated due to a specified maximum cardinality ({?maxOther}) lower than a minimum cardinality ({?min}) on {?property}"
                                                                             ] ;
                                                              sp:variable    _:b2
                                                            ] )
                            ] ;
        spin:labelTemplate  "Inconsistent cardinality constraint"^^xsd:string .


semmowl:MinQualifiedCardinalityConstraint
        a                   spin:Template ;
        rdfs:comment        "Checks for any owl:minQualifiedCardinality restrictions defined in one of the superclasses of the types of ?this and applies them using closed-world semantics." ;
        rdfs:label          "Min qualified cardinality constraint"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a             sp:Construct ;
                              sp:templates  ( [ sp:object     spin:ConstraintViolation ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    _:b1
                                              ] [ sp:object     _:b2 ;
                                                  sp:predicate  rdfs:label ;
                                                  sp:subject    _:b1
                                                ] [ sp:object     spin:_this ;
                                                    sp:predicate  spin:violationRoot ;
                                                    sp:subject    _:b1
                                                  ] [ sp:object     _:b3 ;
                                                      sp:predicate  spin:violationPath ;
                                                      sp:subject    _:b1
                                                    ] ) ;
                              sp:where      ( [ sp:object     _:b4 ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    spin:_this
                                              ] [ a           sp:TriplePath ;
                                                  sp:object   _:b0 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  _:b4
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b0
                                                  ] [ sp:object     _:b7 ;
                                                      sp:predicate  spin:_arg1 ;
                                                      sp:subject    _:b0
                                                    ] [ sp:object     _:b3 ;
                                                        sp:predicate  owl:onProperty ;
                                                        sp:subject    _:b0
                                                      ] [ sp:object     _:b8 ;
                                                        sp:predicate  owl:onClass ;
                                                        sp:subject    _:b0
                                                      ] [ a              sp:Let ;
                                                          sp:expression  [ a        semmcore:objectCount ;
                                                                           sp:arg1  spin:_this ;
                                                                           sp:arg2  _:b3 ;
                                                                           sp:arg3  true ;
                                                                           sp:arg4  _:b8
                                                                         ] ;
                                                          sp:variable    _:b6
                                                        ] [ a              sp:Filter ;
                                                            sp:expression  [ a        sp:lt ;
                                                                             sp:arg1  _:b6 ;
                                                                             sp:arg2  _:b7
                                                                           ]
                                                          ] [ a              sp:Let ;
                                                              sp:expression  [ a        smf:buildString ;
                                                                               sp:arg1  "Instances of {?type} must have minimally {?min} objects of type {?onClass} for {?property}"
                                                                             ] ;
                                                              sp:variable    _:b2
                                                            ] )
                            ] ;
        spin:constraint     [ a              spl:Argument ;
                              rdfs:comment   "the system property (owl:minQualifiedCardinality or owl:qualifiedCardinality)"^^xsd:string ;
                              spl:predicate  sp:arg1 ;
                              spl:valueType  rdf:Property
                            ] ;
        spin:labelTemplate  "MinQualifiedCardinality constraint (using {?arg1})"^^xsd:string .


semmowl:MaxQualifiedCardinalityConstraint
        a                   spin:Template ;
        rdfs:comment        "Checks for any owl:maxQualifiedCardinality/owl:qualifiedCardinality restrictions defined in one of the superclasses of the types of ?this and applies them using closed-world semantics." ;
        rdfs:label          "Max qualified cardinality constraint"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a             sp:Construct ;
                              sp:templates  ( [ sp:object     spin:ConstraintViolation ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    _:b1
                                              ] [ sp:object     _:b2 ;
                                                  sp:predicate  rdfs:label ;
                                                  sp:subject    _:b1
                                                ] [ sp:object     spin:_this ;
                                                    sp:predicate  spin:violationRoot ;
                                                    sp:subject    _:b1
                                                  ] [ sp:object     _:b3 ;
                                                      sp:predicate  spin:violationPath ;
                                                      sp:subject    _:b1
                                                    ] ) ;
                              sp:where      ( [ sp:object     _:b4 ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    spin:_this
                                              ] [ a           sp:TriplePath ;
                                                  sp:object   _:b0 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  _:b4
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b0
                                                  ] [ sp:object     _:b5 ;
                                                      sp:predicate  spin:_arg1 ;
                                                      sp:subject    _:b0
                                                    ] [ sp:object     _:b3 ;
                                                        sp:predicate  owl:onProperty ;
                                                        sp:subject    _:b0
                                                      ] [ sp:object     _:b8 ;
                                                        sp:predicate  owl:onClass ;
                                                        sp:subject    _:b0
                                                      ] [ a              sp:Let ;
                                                          sp:expression  [ a        semmcore:objectCount ;
                                                                           sp:arg1  spin:_this ;
                                                                           sp:arg2  _:b3 ;
                                                                           sp:arg3  true ;
                                                                           sp:arg4  _:b8
                                                                         ] ;
                                                          sp:variable    _:b6
                                                        ] [ a              sp:Filter ;
                                                            sp:expression  [ a        sp:gt ;
                                                                             sp:arg1  _:b6 ;
                                                                             sp:arg2  _:b5
                                                                           ]
                                                          ] [ a              sp:Let ;
                                                              sp:expression  [ a        smf:buildString ;
                                                                               sp:arg1  "Instances of {?type} must have maximally {?max} objects of type {?onClass} for {?property}"
                                                                             ] ;
                                                              sp:variable    _:b2
                                                            ] )
                            ] ;
        spin:constraint     [ a              spl:Argument ;
                              rdfs:comment   "the system property (owl:maxQualifiedCardinality or owl:qualifiedCardinality)"^^xsd:string ;
                              spl:predicate  sp:arg1 ;
                              spl:valueType  rdf:Property
                            ] ;
        spin:labelTemplate  "MaxQualifiedCardinality constraint (using {?arg1})"^^xsd:string .




# Know that this is a check for classes rather than for instances!
semmowl:InconsistentAllValuesFromConstraint1
        a                   spin:Template ;
        rdfs:comment        "Checks for any owl:allValuesFrom restrictions defined in one of the superclasses of ?this and cross-checks them for consistency against other defined restrictions of the following types using closed-world semantics: someValuesFrom, minQualifiedCardinality, qualifiedCardinality, maxValuesFrom." ;
        rdfs:label          "Inconsistent allValuesFrom constraint"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a             sp:Construct ;
                              sp:templates  ( [ sp:object     spin:ConstraintViolation ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    _:b1
                                              ] [ sp:object     _:b2 ;
                                                  sp:predicate  rdfs:label ;
                                                  sp:subject    _:b1
                                                ] [ sp:object     spin:_this ;
                                                    sp:predicate  spin:violationRoot ;
                                                    sp:subject    _:b1
                                                  ] [ sp:object     _:b3 ;
                                                      sp:predicate  spin:violationPath ;
                                                      sp:subject    _:b1
                                                    ] ) ;
                              sp:where      (  [ a           sp:TriplePath ;
                                                  sp:object   _:b0 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  spin:_this
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b0
                                                  ] [ sp:object     _:b8 ;
                                                      sp:predicate  owl:allValuesFrom ;
                                                      sp:subject    _:b0
                                                    ] [ sp:object     _:b3 ;
                                                        sp:predicate  owl:onProperty ;
                                                        sp:subject    _:b0
                                                      ] 
                                                      
                                                      
                                                 [ a           sp:TriplePath ;
                                                  sp:object   _:b10 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  spin:_this
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b10
                                                  ]
                                                  [ sp:object     _:b13 ;
                                                    sp:predicate  owl:onProperty ;
                                                    sp:subject    _:b10
                                                  ]
                                                  [ a           sp:TriplePath ;
                                                        sp:object   _:b3 ;
                                                        sp:path     [ a           sp:ModPath ;
                                                                          sp:modMax   -2 ;
                                                                          sp:modMin   0 ;
                                                                          sp:subPath  rdfs:subPropertyOf
                                                                    ] ;
                                                        sp:subject  _:b13
                                                  ]
                                                  
                                                  
                                                  
                                                  
                                                  [ a       sp:Union ;
                                                    sp:elements (
                                                       ( [ sp:object     _:b18 ;
                                                           sp:predicate  owl:allValuesFrom ;
                                                           sp:subject    _:b10
                                                         ]
                                                         [ a       sp:NotExists ;
                                                           sp:elements (
                                                              [ a       sp:Union ;
                                                                sp:elements ( 
                                                                   (
                                                                      [ sp:object     _:b8 ;
                                                                        sp:predicate  owl:allValuesFrom ;
                                                                        sp:subject    _:b0
                                                                      ]
                                                                      [ a           sp:TriplePath ;
                                                                        sp:object   _:b8 ;
                                                                        sp:path     [ a           sp:ModPath ;
                                                                                      sp:modMax   -2 ;
                                                                                      sp:modMin   0 ;
                                                                                      sp:subPath  rdfs:subClassOf
                                                                                    ] ;
                                                                        sp:subject  _:b18
                                                                      ]
                                                                   )
                                                                   (
                                                                      [ sp:object     _:b8 ;
                                                                        sp:predicate  owl:allValuesFrom ;
                                                                        sp:subject    _:b0
                                                                      ]
                                                                      [ a           sp:TriplePath ;
                                                                        sp:object   _:b18 ;
                                                                        sp:path     [ a           sp:ModPath ;
                                                                                      sp:modMax   -2 ;
                                                                                      sp:modMin   0 ;
                                                                                      sp:subPath  rdfs:subClassOf
                                                                                    ] ;
                                                                        sp:subject  _:b8
                                                                      ]
                                                                   )
                                                                )
                                                              ]
                                                           )
                                                         ]
                                                       )
                                                       ( [ sp:object     _:b8 ;
                                                           sp:predicate  owl:allValuesFrom ;
                                                           sp:subject    _:b0
                                                         ]
                                                         [ a       sp:Union ;
                                                           sp:elements ( 
                                                              ([ sp:object     _:b18 ;
                                                                 sp:predicate  owl:someValuesFrom ;
                                                                 sp:subject    _:b10
                                                              ]) 
                                                              ([ sp:object     _:b17 ;
                                                                 sp:predicate  owl:minQualifiedCardinality ;
                                                                 sp:subject    _:b10
                                                               ]
                                                               [ a              sp:Filter ;
                                                                 sp:expression  [ a        sp:gt ;
                                                                                  sp:arg1  _:b17 ;
                                                                                  sp:arg2  0
                                                                                ]
                                                               ]
                                                               [ sp:object     _:b18 ;
                                                                 sp:predicate  owl:onClass ;
                                                                 sp:subject    _:b10
                                                               ])
                                                              ([ sp:object     _:b16 ;
                                                                 sp:predicate  owl:qualifiedCardinality ;
                                                                 sp:subject    _:b10
                                                               ]
                                                               [ a              sp:Filter ;
                                                                 sp:expression  [ a        sp:gt ;
                                                                                  sp:arg1  _:b16 ;
                                                                                  sp:arg2  0
                                                                                ]
                                                               ]
                                                               [ sp:object     _:b18 ;
                                                                 sp:predicate  owl:onClass ;
                                                                 sp:subject    _:b10
                                                               ])
                                                           )
                                                         ]
                                                         [ a       sp:NotExists ;
                                                           sp:elements ( [ a           sp:TriplePath ;
                                                                           sp:object   _:b8 ;
                                                                           sp:path     [ a           sp:ModPath ;
                                                                                         sp:modMax   -2 ;
                                                                                         sp:modMin   0 ;
                                                                                         sp:subPath  rdfs:subClassOf
                                                                                       ] ;
                                                                           sp:subject  _:b18
                                                                         ] )
                                                         ]
                                                       )
                                                    )
                                                  ]
                                                   
                                                  [ a      sp:Let ;
                                                              sp:expression  [ a        smf:buildString ;
                                                                               sp:arg1  "Class {?this} cannot be instantiated as {?property} must relate to instances of {?onClass} only, which conflicts with required instances of {?onClassOther}"
                                                                                                                              
                                                                             ] ;
                                                              sp:variable    _:b2
                                                   ] )
                            ] ;
        spin:labelTemplate  "Inconsistent allValuesFrom constraint #1"^^xsd:string .


# Know that this is a check for classes rather than for instances!
semmowl:InconsistentAllValuesFromConstraint2
        a                   spin:Template ;
        rdfs:comment        "Checks for any owl:allValuesFrom restrictions defined in one of the superclasses of ?this and cross-checks them for consistency against other defined restrictions of the following types using closed-world semantics: hasValue." ;
        rdfs:label          "Inconsistent hasValue constraint"^^xsd:string ;
        rdfs:subClassOf     spin:Templates ;
        spin:body           [ a             sp:Construct ;
                              sp:templates  ( [ sp:object     spin:ConstraintViolation ;
                                                sp:predicate  rdf:type ;
                                                sp:subject    _:b1
                                              ] [ sp:object     _:b2 ;
                                                  sp:predicate  rdfs:label ;
                                                  sp:subject    _:b1
                                                ] [ sp:object     spin:_this ;
                                                    sp:predicate  spin:violationRoot ;
                                                    sp:subject    _:b1
                                                  ] [ sp:object     _:b3 ;
                                                      sp:predicate  spin:violationPath ;
                                                      sp:subject    _:b1
                                                    ] ) ;
                              sp:where      (  [ a           sp:TriplePath ;
                                                  sp:object   _:b0 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  spin:_this
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b0
                                                  ] [ sp:object     _:b8 ;
                                                      sp:predicate  owl:allValuesFrom ;
                                                      sp:subject    _:b0
                                                    ] [ sp:object     _:b3 ;
                                                        sp:predicate  owl:onProperty ;
                                                        sp:subject    _:b0
                                                      ] 
                                                      
                                                      
                                                 [ a           sp:TriplePath ;
                                                  sp:object   _:b10 ;
                                                  sp:path     [ a           sp:ModPath ;
                                                                sp:modMax   -2 ;
                                                                sp:modMin   0 ;
                                                                sp:subPath  rdfs:subClassOf
                                                              ] ;
                                                  sp:subject  spin:_this
                                                ] [ sp:object     owl:Restriction ;
                                                    sp:predicate  rdf:type ;
                                                    sp:subject    _:b10
                                                  ]
                                                  [ sp:object     _:b13 ;
                                                    sp:predicate  owl:onProperty ;
                                                    sp:subject    _:b10
                                                  ]
                                                  [ a           sp:TriplePath ;
                                                        sp:object   _:b3 ;
                                                        sp:path     [ a           sp:ModPath ;
                                                                          sp:modMax   -2 ;
                                                                          sp:modMin   0 ;
                                                                          sp:subPath  rdfs:subPropertyOf
                                                                    ] ;
                                                        sp:subject  _:b13
                                                  ]
                                                  
                                                  
                                                  
                                                  [ sp:object     _:b19 ;
                                                    sp:predicate  owl:hasValue ;
                                                    sp:subject    _:b10
                                                  ]
                                                  [ a       sp:NotExists ;
                                                             sp:elements ( [ sp:object     _:b20 ;
                                                                             sp:predicate  rdf:type ;
                                                                             sp:subject    _:b19
                                                                           ]
                                                                           [ a           sp:TriplePath ;
                                                                               sp:object   _:b8 ;
                                                                               sp:path     [ a           sp:ModPath ;
                                                                                             sp:modMax   -2 ;
                                                                                             sp:modMin   0 ;
                                                                                             sp:subPath  rdfs:subClassOf
                                                                                           ] ;
                                                                               sp:subject  _:b20
                                                                           ] )
                                                   ]
                                                   [ a              sp:Let ;
                                                              sp:expression  [ a        smf:buildString ;
                                                                               sp:arg1  "Class {?this} cannot be instantiated as {?property} must relate to instances of {?onClass} only, which conflicts with required instance {?hasValueOther}"
                                                                                                                              
                                                                             ] ;
                                                              sp:variable    _:b2
                                                   ] )
                            ] ;
        spin:labelTemplate  "Inconsistent allValuesFrom constraint #2"^^xsd:string .




_:b_list      sp:varName  "list"^^xsd:string .
_:b_member    sp:varName  "member"^^xsd:string .

_:b0    sp:varName  "class"^^xsd:string .
_:b2    sp:varName  "label"^^xsd:string .
_:b3    sp:varName  "property"^^xsd:string .
_:b4    sp:varName  "type"^^xsd:string .
_:b5    sp:varName  "max"^^xsd:string .
_:b6    sp:varName  "cardinality"^^xsd:string .
_:b7    sp:varName  "min"^^xsd:string .
_:b8    sp:varName  "onClass"^^xsd:string .

